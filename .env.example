# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_me_64_byte_hex_access_secret
JWT_REFRESH_SECRET=replace_me_64_byte_hex_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Admin Auth ───────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Generate with: node -e "const b=require('bcryptjs');b.hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$12$replace_this_with_real_bcrypt_hash

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local Docker: mongodb://admin:leadgen_secret@localhost:27017/leadgen?authSource=admin
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/leadgen
MONGODB_URI=mongodb://admin:leadgen_secret@localhost:27017/leadgen?authSource=admin

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Encryption (AES-256-GCM) ─────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_me_32_byte_hex_encryption_key

# ─── Groq AI ──────────────────────────────────────────────────────────────────
# Get free API key at: https://console.groq.com
GROQ_API_KEY=gsk_replace_with_your_groq_api_key

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
